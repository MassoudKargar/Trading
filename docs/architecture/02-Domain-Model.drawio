from textwrap import dedent
xml=dedent("""\
<mxfile host="app.diagrams.net" modified="2026-07-14T00:00:00Z" agent="ChatGPT" version="24.7.0">
<diagram id="domain" name="Domain Model">
<mxGraphModel dx="1600" dy="900" grid="1" gridSize="10"><root>
<mxCell id="0"/><mxCell id="1" parent="0"/>
""")
entities=[
("Account",40,40),("Portfolio",320,40),("Position",620,40),("Order",920,40),
("Trade",1220,40),("Strategy",320,260),("Indicator",620,260),
("RiskProfile",920,260),("Symbol",40,260),("Tick",40,500),
("Candle",320,500),("OrderBook",620,500)
]
cells=[]
edges=[]
for i,(n,x,y) in enumerate(entities, start=2):
    cells.append(f'''<mxCell id="{i}" value="{n}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="{x}" y="{y}" width="180" height="70" as="geometry"/></mxCell>''')
idmap={n:str(i) for i,(n,_,_) in enumerate(entities,start=2)}
rels=[("Account","Portfolio"),("Portfolio","Position"),("Position","Order"),("Position","Trade"),
("Strategy","Indicator"),("Strategy","RiskProfile"),("Position","Symbol"),("Symbol","Tick"),
("Symbol","Candle"),("Symbol","OrderBook")]
eid=100
for s,t in rels:
    edges.append(f'<mxCell id="{eid}" edge="1" parent="1" source="{idmap[s]}" target="{idmap[t]}"><mxGeometry relative="1" as="geometry"/></mxCell>')
    eid+=1
xml+="\n".join(cells+edges)
xml+="</root></mxGraphModel></diagram></mxfile>"
path="/mnt/data/02-Domain-Model.drawio"
with open(path,"w",encoding="utf-8") as f:f.write(xml)
print(path)
