from textwrap import dedent

tables = [
("Accounts",40,40),
("Portfolios",340,40),
("Positions",640,40),
("Orders",940,40),
("Trades",1240,40),
("Strategies",40,280),
("Indicators",340,280),
("RiskProfiles",640,280),
("Symbols",940,280),
("Ticks",1240,280),
("Candles",940,520),
("OrderBooks",1240,520),
]

fields = {
"Accounts":"PK Id\nBrokerId\nBalance\nEquity\nMargin",
"Portfolios":"PK Id\nFK AccountId",
"Positions":"PK Id\nFK PortfolioId\nFK SymbolId\nFK StrategyId",
"Orders":"PK Id\nFK PositionId",
"Trades":"PK Id\nFK PositionId",
"Strategies":"PK Id\nName\nType",
"Indicators":"PK Id\nFK StrategyId",
"RiskProfiles":"PK Id\nName",
"Symbols":"PK Id\nName\nBaseCurrency\nQuoteCurrency",
"Ticks":"PK Id\nFK SymbolId\nBid\nAsk",
"Candles":"PK Id\nFK SymbolId\nTimeFrame",
"OrderBooks":"PK Id\nFK SymbolId"
}

xml = ['<mxfile host="app.diagrams.net" version="24.7.0"><diagram id="erd" name="Database ERD"><mxGraphModel><root><mxCell id="0"/><mxCell id="1" parent="0"/>']
idmap={}
i=2
for name,x,y in tables:
    idmap[name]=str(i)
    val=f"<b>{name}</b><br/>{fields[name].replace(chr(10),'<br/>')}"
    xml.append(f'<mxCell id="{i}" value="{val}" style="shape=swimlane;html=1;rounded=0;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="{x}" y="{y}" width="220" height="150" as="geometry"/></mxCell>')
    i+=1
rels=[
("Accounts","Portfolios"),
("Portfolios","Positions"),
("Positions","Orders"),
("Positions","Trades"),
("Strategies","Positions"),
("Strategies","Indicators"),
("Symbols","Positions"),
("Symbols","Ticks"),
("Symbols","Candles"),
("Symbols","OrderBooks"),
]
e=100
for s,t in rels:
    xml.append(f'<mxCell id="{e}" edge="1" parent="1" source="{idmap[s]}" target="{idmap[t]}"><mxGeometry relative="1" as="geometry"/></mxCell>')
    e+=1
xml.append("</root></mxGraphModel></diagram></mxfile>")
path="/mnt/data/03-Database-ERD.drawio"
with open(path,"w",encoding="utf-8") as f:
    f.write("\n".join(xml))
print(path)
